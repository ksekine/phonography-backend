# ローカル開発用シークレットの雛形。
# このファイルを .dev.vars にコピーして実際の値を設定する(.dev.vars は gitignore 済み)。
# デプロイ環境のシークレットは GitHub Environments (dev/prod) の Secrets で管理し、
# .github/workflows/deploy-*.yml の secrets ブロックで Worker に同期する。

# R2 署名付きURL生成用 (S3互換API)。
# Cloudflare ダッシュボード → R2 → Manage R2 API Tokens で
# 対象バケットに Object Read & Write をスコープしたトークンを発行して取得する。
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key

# FCM HTTP v1用サービスアカウント。秘密鍵は改行を\\nにした1行でもよい。
FCM_SERVICE_ACCOUNT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
FCM_SERVICE_ACCOUNT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n

# 認証は Firebase Authentication。ID トークンは Google の公開 JWKS で検証するため
# サーバー側のシークレットは不要(プロジェクト ID は wrangler.jsonc の vars で管理)。
